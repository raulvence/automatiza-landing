---
import { SITE, WHATSAPP_LINK } from '~/config';
---

<section id="chat" class="border-t border-line bg-surface">
  <div class="container-narrow py-24 md:py-32">

    <div class="grid md:grid-cols-12 gap-8 mb-16 items-end">
      <div class="md:col-span-7">
        <p class="label-mono mb-5">
          <span class="text-accent">§ 04</span> &nbsp; Asistente
        </p>
        <h2 class="font-display font-bold tracking-tightest leading-[0.95]"
            style="font-size: clamp(2.25rem, 5.5vw, 4.5rem);">
          Pregúntame<br />
          <span class="italic font-medium text-accent-dim">lo que necesitas saber.</span>
        </h2>
      </div>
      <div class="md:col-span-5 md:pl-8">
        <p class="text-muted text-lg leading-relaxed">
          ¿Cuánto cuesta automatizar X? ¿Cuánto tiempo tarda? Pregunta directo — respondo en segundos.
        </p>
      </div>
    </div>

    <!-- Terminal window -->
    <div class="relative max-w-3xl">
      <div class="terminal-glow" aria-hidden="true"></div>
      <div
        class="relative border border-line bg-bg font-mono text-sm"
        data-webhook={SITE.chatWebhook}
        data-whatsapp={WHATSAPP_LINK}
      >

        <!-- Title bar -->
        <div class="border-b border-line px-4 py-2.5 flex items-center gap-3">
          <div class="flex gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-line"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-line"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-accent" style="opacity:0.7"></span>
          </div>
          <span class="text-[10px] uppercase tracking-[0.2em] text-muted ml-1">automatiza — asistente ia</span>
          <span class="ml-auto flex items-center gap-1.5 text-[10px] text-accent">
            <span class="live-dot" style="width:5px;height:5px;"></span>
            ONLINE
          </span>
        </div>

        <!-- Log -->
        <div id="chat-log" class="px-5 py-5 space-y-3 min-h-[220px] max-h-[360px] overflow-y-auto">
          <div class="text-muted">$ automatiza --chat --init</div>
          <div><span class="text-accent">→</span> <span class="text-accent">Hola. Antes de empezar, ¿cómo te llamo?</span></div>
        </div>

        <!-- Input -->
        <div class="border-t border-line px-5 py-3 flex items-center gap-3">
          <span class="text-accent select-none">›</span>
          <input
            id="chat-input"
            type="text"
            placeholder="tu nombre..."
            autocomplete="off"
            class="flex-1 bg-transparent text-ink placeholder-dim outline-none text-sm font-mono"
          />
          <button
            id="chat-send"
            class="text-[10px] uppercase tracking-[0.15em] text-accent hover:text-ink border border-line hover:border-accent px-3 py-1.5 transition-all duration-300"
          >
            enter
          </button>
        </div>

      </div>
    </div>

    <p class="font-mono text-[11px] text-dim mt-4">
      // respuestas generadas por IA · pueden contener errores · confirma detalles con hola@automatiza.com.pa
    </p>

  </div>
</section>

<style>
  .typing-dots span {
    animation: blink-dot 1.2s infinite;
    opacity: 0;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes blink-dot {
    0%, 80%, 100% { opacity: 0; }
    40% { opacity: 1; }
  }
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    padding: 6px 14px;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .btn-whatsapp:hover {
    background: var(--accent);
    color: var(--bg);
  }
</style>

<script>
  const terminal = document.querySelector('[data-webhook]') as HTMLElement;
  const webhookUrl = terminal?.dataset.webhook ?? '/api/chat';
  const whatsappUrl = terminal?.dataset.whatsapp ?? '#';
  const log = document.getElementById('chat-log') as HTMLElement;
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;

  let state: 'name' | 'whatsapp' | 'chat' = 'name';
  let leadName = '';
  let leadWhatsapp = '';

  function escapeHtml(str: string) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function appendLine(text: string, type: 'user' | 'bot' | 'system') {
    const div = document.createElement('div');
    if (type === 'user') {
      div.innerHTML = `<span class="text-muted">›</span> <span style="color:#fff">${escapeHtml(text)}</span>`;
    } else if (type === 'bot') {
      div.innerHTML = `<span class="text-accent">→</span> <span class="text-accent">${escapeHtml(text)}</span>`;
    } else {
      div.className = 'text-muted text-[11px]';
      div.textContent = text;
    }
    log.appendChild(div);
    log.scrollTop = log.scrollHeight;
  }

  function appendWhatsAppButton() {
    const div = document.createElement('div');
    div.innerHTML = `<a href="${whatsappUrl}" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">→ Contactar por WhatsApp</a>`;
    log.appendChild(div);
    log.scrollTop = log.scrollHeight;
  }

  function showTyping(): HTMLElement {
    const div = document.createElement('div');
    div.id = 'typing-indicator';
    div.innerHTML = `<span class="text-accent">→</span> <span class="text-accent typing-dots"><span>.</span><span>.</span><span>.</span></span>`;
    log.appendChild(div);
    log.scrollTop = log.scrollHeight;
    return div;
  }

  function removeTyping() {
    document.getElementById('typing-indicator')?.remove();
  }

  function delay(ms: number) {
    return new Promise(r => setTimeout(r, ms));
  }

  async function botReply(text: string, ms = 900) {
    showTyping();
    await delay(ms);
    removeTyping();
    appendLine(text, 'bot');
  }

  async function handleInput() {
    const val = input.value.trim();
    if (!val) return;
    input.value = '';
    sendBtn.disabled = true;

    if (state === 'name') {
      leadName = val;
      appendLine(val, 'user');
      await botReply(`Hola, ${leadName}. ¿Y tu número de WhatsApp para darte seguimiento?`);
      input.placeholder = 'tu WhatsApp (ej: 50766...)';
      sendBtn.disabled = false;
      state = 'whatsapp';
      return;
    }

    if (state === 'whatsapp') {
      leadWhatsapp = val;
      appendLine(val, 'user');
      await botReply(`Listo, ${leadName}. ¿En qué puedo ayudarte?`, 700);
      appendLine('// pregunta sobre servicios, precios o plazos', 'system');
      input.placeholder = 'escribe tu pregunta...';
      sendBtn.textContent = 'enviar';
      sendBtn.disabled = false;
      state = 'chat';
      return;
    }

    // Chat mode
    appendLine(val, 'user');
    showTyping();
    sendBtn.textContent = '...';

    try {
      const res = await fetch(webhookUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: val, name: leadName, whatsapp: leadWhatsapp }),
      });
      const data = await res.json();
      removeTyping();

      const raw: string = data.reply ?? 'Sin respuesta.';
      const showContact = raw.includes('[CONTACTO]');
      const cleanReply = raw.replace('[CONTACTO]', '').trim();

      appendLine(cleanReply, 'bot');
      if (showContact) appendWhatsAppButton();
    } catch {
      removeTyping();
      appendLine('// error de conexión', 'system');
    }

    sendBtn.disabled = false;
    sendBtn.textContent = 'enviar';
    input.focus();
  }

  sendBtn.addEventListener('click', handleInput);
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter') handleInput(); });
</script>
