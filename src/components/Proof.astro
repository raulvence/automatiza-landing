---

<section id="trabajo" class="border-t border-line bg-surface">
  <div class="container-narrow py-24 md:py-32">

    <!-- Section header -->
    <div class="mb-20 md:mb-24">
      <p class="label-mono mb-5">
        <span class="text-accent">§ 02</span> &nbsp; Trabajo en producción
      </p>
      <h2 class="font-display font-bold tracking-tightest leading-[0.95] mb-8"
          style="font-size: clamp(2.25rem, 5.5vw, 4.5rem);">
        No son demos.<br />
        <span class="italic font-medium text-accent-dim">Están corriendo ahora.</span>
      </h2>
      <p class="text-muted text-lg max-w-2xl leading-relaxed">
        Cada uno de estos sistemas está en producción y bajo mi mantenimiento. Click en el nombre para verlos en vivo.
      </p>
    </div>

    <!-- Lista terminal-style -->
    <div class="space-y-px bg-line">
      {projects.map((p, i) => (
        <article class="bg-surface group hover:bg-elevated transition-colors duration-500">
          <div class="grid md:grid-cols-12 gap-6 p-7 md:p-9">

            <!-- Comando + tipo -->
            <div class="md:col-span-4">
              <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted mb-3">
                $ deploy / {String(i + 1).padStart(2, '0')}
              </div>
              <h3 class="font-display font-bold text-2xl md:text-3xl tracking-tighter leading-tight mb-2">
                {p.link ? (
                  <a
                    href={p.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-accent transition-colors inline-flex items-center gap-2 group/link"
                  >
                    {p.cmd}
                    <span class="text-base text-accent-dim group-hover/link:translate-x-1 group-hover/link:translate-y-[-1px] transition-transform inline-block">↗</span>
                  </a>
                ) : p.screenshots ? (
                  <button
                    class="hover:text-accent transition-colors inline-flex items-center gap-2 group/link text-left demo-trigger"
                    data-screenshots={JSON.stringify(p.screenshots)}
                    data-title={p.cmd}
                  >
                    {p.cmd}
                    <span class="text-base text-accent-dim group-hover/link:translate-x-1 transition-transform inline-block">▶</span>
                  </button>
                ) : p.terminal ? (
                  <button
                    class="hover:text-accent transition-colors inline-flex items-center gap-2 group/link text-left terminal-trigger"
                    data-steps={JSON.stringify(p.terminal)}
                    data-title={p.cmd}
                  >
                    {p.cmd}
                    <span class="text-base text-accent-dim group-hover/link:translate-x-1 transition-transform inline-block">▶</span>
                  </button>
                ) : (
                  <span>{p.cmd}</span>
                )}
              </h3>
              <p class="font-mono text-xs text-accent-dim">// {p.type}</p>
            </div>

            <!-- Body -->
            <div class="md:col-span-5">
              <p class="text-ink/80 leading-relaxed mb-4">
                {p.body}
              </p>
              <div class="font-mono text-[11px] text-muted">
                stack: <span class="text-ink/60">{p.stack}</span>
              </div>
            </div>

            <!-- Métricas -->
            <div class="md:col-span-3 space-y-2.5 md:border-l md:border-line md:pl-6">
              {p.metrics.map((m) => (
                <div class="flex items-baseline justify-between gap-3 font-mono text-xs">
                  <span class="text-muted">{m.label}</span>
                  <span class="text-accent tabular-nums">{m.value}</span>
                </div>
              ))}
            </div>

          </div>
        </article>
      ))}
    </div>

    <!-- Footnote -->
    <p class="font-mono text-[11px] text-dim mt-8">
      // 6 sistemas listados · más casos disponibles bajo NDA
    </p>

  </div>
</section>

<!-- Modal terminal pipeline -->
<div id="terminal-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4">
  <div class="relative w-full max-w-2xl">
    <button id="terminal-close" class="absolute -top-8 right-0 font-mono text-xs text-muted hover:text-ink transition-colors tracking-widest uppercase">cerrar ×</button>
    <div class="border border-line bg-bg font-mono text-sm">
      <div class="border-b border-line px-4 py-2.5 flex items-center gap-3">
        <div class="flex gap-1.5">
          <span class="w-2.5 h-2.5 rounded-full bg-line"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-line"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-accent" style="opacity:0.7"></span>
        </div>
        <span id="terminal-title" class="text-[10px] uppercase tracking-[0.2em] text-muted ml-1"></span>
        <span class="ml-auto flex items-center gap-1.5 text-[10px] text-accent">
          <span class="live-dot" style="width:5px;height:5px;"></span>
          RUNNING
        </span>
      </div>
      <div id="terminal-log" class="px-5 py-5 space-y-2 min-h-[260px]"></div>
    </div>
  </div>
</div>

<!-- Modal demo celular -->
<div id="phone-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4">
  <div class="relative flex flex-col items-center">

    <!-- Cerrar -->
    <button id="phone-close" class="absolute -top-10 right-0 font-mono text-xs text-muted hover:text-ink transition-colors tracking-widest uppercase">
      cerrar ×
    </button>

    <!-- Título -->
    <p id="phone-title" class="font-mono text-[11px] uppercase tracking-[0.2em] text-accent mb-6"></p>

    <!-- Phone frame -->
    <div class="relative bg-[#0a0a0a] rounded-[40px] p-3 shadow-2xl" style="width:280px; border: 2px solid #222;">
      <!-- Notch -->
      <div class="absolute top-3 left-1/2 -translate-x-1/2 w-20 h-5 bg-[#0a0a0a] rounded-full z-10"></div>
      <!-- Screen -->
      <div class="relative overflow-hidden rounded-[30px] bg-black" style="height:560px;">
        <img id="phone-img" src="" alt="" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500" />
      </div>
      <!-- Home indicator -->
      <div class="mt-2 mx-auto w-20 h-1 bg-[#333] rounded-full"></div>
    </div>

    <!-- Dots -->
    <div id="phone-dots" class="flex gap-2 mt-5"></div>
  </div>
</div>

<script>
  const modal   = document.getElementById('phone-modal') as HTMLElement;
  const closeBtn = document.getElementById('phone-close') as HTMLElement;
  const phoneImg = document.getElementById('phone-img') as HTMLImageElement;
  const titleEl  = document.getElementById('phone-title') as HTMLElement;
  const dotsEl   = document.getElementById('phone-dots') as HTMLElement;

  let slides: string[] = [];
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function showSlide(idx: number) {
    current = idx;
    phoneImg.style.opacity = '0';
    setTimeout(() => {
      phoneImg.src = slides[current];
      phoneImg.style.opacity = '1';
    }, 250);
    dotsEl.querySelectorAll('span').forEach((d, i) => {
      d.className = i === current
        ? 'w-4 h-1.5 rounded-full bg-accent transition-all duration-300'
        : 'w-1.5 h-1.5 rounded-full bg-line transition-all duration-300';
    });
  }

  function openDemo(screenshots: string[], title: string) {
    slides = screenshots;
    current = 0;
    titleEl.textContent = `$ demo / ${title}`;
    dotsEl.innerHTML = slides.map((_, i) =>
      `<span class="${i === 0 ? 'w-4 h-1.5 rounded-full bg-accent' : 'w-1.5 h-1.5 rounded-full bg-line'} transition-all duration-300"></span>`
    ).join('');
    phoneImg.src = slides[0];
    phoneImg.style.opacity = '1';
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    clearInterval(timer);
    timer = setInterval(() => showSlide((current + 1) % slides.length), 2500);
  }

  // Terminal modal
  const termModal   = document.getElementById('terminal-modal') as HTMLElement;
  const termClose   = document.getElementById('terminal-close') as HTMLElement;
  const termLog     = document.getElementById('terminal-log') as HTMLElement;
  const termTitle   = document.getElementById('terminal-title') as HTMLElement;
  let termTimers: ReturnType<typeof setTimeout>[] = [];

  function openTerminal(steps: any[], title: string) {
    termLog.innerHTML = '';
    termTitle.textContent = title;
    termTimers.forEach(clearTimeout);
    termTimers = [];
    termModal.classList.remove('hidden');
    termModal.classList.add('flex');

    let lastRunningEl: HTMLElement | null = null;

    steps.forEach((step: any) => {
      const t = setTimeout(() => {
        if (step.replace && lastRunningEl) {
          lastRunningEl.remove();
          lastRunningEl = null;
        }
        if (step.type === 'blank') return;

        const div = document.createElement('div');
        if (step.type === 'cmd') {
          div.innerHTML = `<span class="text-muted">${step.text}</span>`;
        } else if (step.type === 'running') {
          div.innerHTML = `<span class="text-accent">→</span> <span class="text-muted">${step.text}</span> <span class="text-dim animate-pulse">...</span>`;
          lastRunningEl = div;
        } else if (step.type === 'done') {
          div.innerHTML = `<span class="text-accent">→</span> <span class="text-ink">${step.text}</span>`;
        } else if (step.type === 'success') {
          div.innerHTML = `<span class="text-accent font-bold">${step.text}</span>`;
        }
        termLog.appendChild(div);
        termLog.scrollTop = termLog.scrollHeight;
      }, step.delay);
      termTimers.push(t);
    });
  }

  function closeTerminal() {
    termTimers.forEach(clearTimeout);
    termModal.classList.add('hidden');
    termModal.classList.remove('flex');
  }

  document.querySelectorAll('.terminal-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const steps = JSON.parse((btn as HTMLElement).dataset.steps || '[]');
      const title = (btn as HTMLElement).dataset.title || '';
      openTerminal(steps, title);
    });
  });

  termClose.addEventListener('click', closeTerminal);
  termModal.addEventListener('click', (e) => { if (e.target === termModal) closeTerminal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeTerminal(); closeDemo(); } });

  document.querySelectorAll('.demo-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const screenshots = JSON.parse((btn as HTMLElement).dataset.screenshots || '[]');
      const title = (btn as HTMLElement).dataset.title || '';
      openDemo(screenshots, title);
    });
  });

  function closeDemo() {
    clearInterval(timer);
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  closeBtn.addEventListener('click', closeDemo);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeDemo(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDemo(); });
</script>
