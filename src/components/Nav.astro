---
import { SITE, WHATSAPP_LINK } from '~/config';
---

<header class="border-b border-line bg-bg/60 backdrop-blur-xl sticky top-0 z-40">
  <div class="container-narrow flex items-center justify-between h-14">

    <!-- Brand -->
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Automatiza inicio">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="22 22 76 61" width="28" height="28" fill="none" aria-hidden="true">
        <circle cx="30" cy="30" r="8" fill="#9ce824" />
        <circle cx="90" cy="30" r="8" fill="#9ce824" />
        <circle cx="60" cy="75" r="8" fill="#9ce824" />
        <line x1="30" y1="30" x2="90" y2="30" stroke="#9ce824" stroke-width="2.5" />
        <line x1="30" y1="30" x2="60" y2="75" stroke="#9ce824" stroke-width="2.5" />
        <line x1="90" y1="30" x2="60" y2="75" stroke="#9ce824" stroke-width="2.5" />
      </svg>
      <span class="font-display font-semibold text-base tracking-tighter">automatiza</span>
      <span class="font-mono text-xs text-muted hidden sm:inline">.com.pa</span>
    </a>

    <!-- Nav links desktop -->
    <nav class="hidden md:flex items-center gap-7 text-sm">
      <a href="#servicios" class="text-muted hover:text-ink transition-colors">Servicios</a>
      <a href="#trabajo" class="text-muted hover:text-ink transition-colors">Trabajo</a>
      <a href="#proceso" class="text-muted hover:text-ink transition-colors">Proceso</a>
      <a
        href={WHATSAPP_LINK}
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium text-ink hover:text-accent transition-colors flex items-center gap-1.5"
      >
        Hablemos <span aria-hidden="true">→</span>
      </a>
    </nav>

    <!-- Mobile CTA -->
    <a
      href={WHATSAPP_LINK}
      target="_blank"
      rel="noopener noreferrer"
      class="md:hidden text-sm font-medium text-accent flex items-center gap-1.5"
    >
      Hablemos <span aria-hidden="true">→</span>
    </a>

  </div>
</header>
